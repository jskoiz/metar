# metar-proxy environment configuration
# Copy to .env and fill in values

# X (Twitter) API Bearer Token (required)
X_BEARER_TOKEN=your_x_api_bearer_token_here

# Wallet address to receive USDC payments (required)
# This is YOUR provider wallet address on the target chain
WALLET_ADDRESS=your_solana_wallet_address_here

# Ethereum/Base wallet address for EVM chain payments (optional, uses WALLET_ADDRESS if not set)
EVM_WALLET_ADDRESS=0xYourEthereumOrBaseWalletAddressHere

# Server port (default: 4200)
PORT=4200

# Solana network: "devnet" or "mainnet" (default: devnet)
SOLANA_NETWORK=devnet

# Solana RPC URLs (optional, uses public nodes if not set)
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
SOLANA_MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Facilitator mode - verify payments via facilitator service
# FACILITATOR_URL=https://your-facilitator.example.com

# Optional: Agent Registry URL (for TAP agent discovery)
# AGENT_REGISTRY_URL=https://registry.example.com
