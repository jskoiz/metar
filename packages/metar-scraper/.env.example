# metar-scraper environment configuration
# Copy to .env and fill in values

# Path to the x-follow-grabber project
XFOLLOWGRABBER_PATH=/Users/jerry/Desktop/x-follow-grabber

# Solana wallet address to receive USDC payments
# Must be a base58-encoded Solana public key (e.g. 7xKXtg2CZ3Qz4qKzJq...)
# NOT an EVM/Ethereum address
WALLET_ADDRESS=your_solana_base58_wallet_address_here

# Port to run the scraper API server on
PORT=3003

# Solana network (devnet or mainnet)
SOLANA_NETWORK=devnet

# Optional: Solana RPC URL overrides
# SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
# SOLANA_MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# Facilitator service URL for payment verification (recommended)
# x402.org supports solana-devnet and solana
FACILITATOR_URL=https://x402.org/facilitator
